{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": false
  },
  "include": ["src"],
  "exclude": ["src/**/*.d.ts", "dist", "node_modules"]
}
